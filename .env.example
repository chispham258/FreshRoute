# Database (Optional - for metrics and tracking)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/freshroute
DATABASE_POOL_SIZE=10

# Firebase (Optional - for caching)
FIREBASE_PROJECT_ID=freshroute-hackathon
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# FPT AI Factory (Required for agent endpoints)
# Get your API key from FPT AI Factory and set the model ID
OPENAI_API_KEY=your-fpt-ai-api-key-here
OPENAI_MODEL=your-fpt-model-id-here
TEMPERATURE=0.1

# Note: The API endpoint is hardcoded to https://mkp-api.fptcloud.com/v1
# in both B2B and Consumer agents for FPT AI Factory compatibility.

# Pipeline Configuration
P1_TOP_N=20
P2_TOP_K=20
P6_TOP_K=10
BUNDLE_CACHE_TTL_SECONDS=3600
MIN_IMPRESSIONS_FOR_LEARNING=200

# Store Connector
DEFAULT_CONNECTOR=mock
STORE_DB_HOST=
STORE_DB_PORT=
STORE_DB_NAME=
STORE_DB_USER=
STORE_DB_PASSWORD=

# Logging (Optional)
LOG_LEVEL=INFO
