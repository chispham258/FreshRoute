: {'name': 'get_recipe_by_name', 'description': 'Find a recipe by Vietnamese name (fuzzy match). Use when user wants to cook a specific dish.', 'parameters': {'properties': {'recipe_name': {'type': 'string'}}, 'required': ['recipe_name'], 'type': 'object'}}}, {'type': 'function', 'function': {'name': 'get_remaining_ingredients', 'description': 'Compute what ingredients user still needs to buy for a recipe given what they already have.', 'parameters': {'properties': {'recipe_id': {'type': 'string'}, 'available_ingredients': {'items': {'type': 'string'}, 'type': 'array'}, 'allergies': {'anyOf': [{'items': {'type': 'string'}, 'type': 'array'}, {'type': 'null'}], 'default': None}, 'substitutions': {'anyOf': [{'type': 'object'}, {'type': 'null'}], 'default': None}}, 'required': ['recipe_id', 'available_ingredients'], 'type': 'object'}}}, {'type': 'function', 'function': {'name': 'get_ingredient_suggestions', 'description': 'Get substitute suggestions for missing ingredients in a recipe the user wants to cook.', 'parameters': {'properties': {'recipe_id': {'type': 'string'}, 'available_ingredients': {'items': {'type': 'string'}, 'type': 'array'}}, 'required': ['recipe_id', 'available_ingredients'], 'type': 'object'}}}, {'type': 'function', 'function': {'name': 'query_ontology', 'description': 'Look up ingredient relationships in the Vietnamese food ontology.', 'parameters': {'properties': {'ingredient_id': {'type': 'string'}, 'relation': {'default': 'substitute', 'type': 'string'}}, 'required': ['ingredient_id'], 'type': 'object'}}}, {'type': 'function', 'function': {'name': 'note_allergy', 'description': 'Record food allergies for this conversation. Call this IMMEDIATELY when the user mentions anything they cannot eat (dị ứng, không ăn được, etc.). Returns allergy_ids — pass these to find_recipes_for_consumer and adjust_recipe_for_user.', 'parameters': {'properties': {'allergy_names': {'items': {'type': 'string'}, 'type': 'array'}}, 'required': ['allergy_names'], 'type': 